if ARCH_BOARD_RASPBERRYPI_4B

    # TODO: make this option a multi-select instead of range select
    config RPI4B_RAM
        int "Raspberry Pi 4B RAM size (in GB)"
        default 4
        ---help---
            The size of the Raspberry Pi 4B's RAM in GB. Supports
            1GB, 2GB, 4GB and 8GB models.

    config RPI4B_DEBUG_BOOT
        bool "Raspberry Pi 4B bootloader debug output"
        default n
        ---help---
            Enables the debug output of the Raspberry Pi 4B bootloader.


endif # ARCH_BOARD_RASPBERRYPI_4B
